// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Kumaş ve Hammadde Stokları
model Material {
  id            Int      @id @default(autoincrement())
  name          String
  sku           String?  @unique
  color         String   // Renk (zorunlu)
  type          String   // FABRIC, THREAD, ACCESSORY
  quantity      Float    // Stok miktarı (Metre cinsinden)
  unit          String   // METER, PIECE
  unitPrice     Float    // Birim maliyet
  widthCm       Float?   // Kumaş eni (cm)
  gsm           Float?   // Gramaj (g/m²)
  supplier      String?
  reorderLevel  Float?   // Kritik stok seviyesi
  lastStockCheck DateTime?

  movements     StockMovement[]
}

// Ürün Tanımları (Örn: Perde, Yastık Kılıfı)
model Product {
  id          Int      @id @default(autoincrement())
  name        String
  sku         String   @unique
  description String?

  orders       OrderItem[]
  optionGroups OptionGroup[]
}

// Ürün Seçenek Grupları (Örn: "Header Tipi", "Astar Tipi")
model OptionGroup {
  id        Int      @id @default(autoincrement())
  productId Int
  name      String   // Grup adı (Örn: "Header Tipi")
  sortOrder Int      @default(0)

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  options   Option[]
}

// Seçenekler (Örn: "Tab Top", "Rod Pocket", "Grommet")
model Option {
  id        Int      @id @default(autoincrement())
  groupId   Int
  label     String   // Seçenek adı
  sortOrder Int      @default(0)

  group     OptionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

// Siparişler
model Order {
  id            Int      @id @default(autoincrement())
  etsyOrderId   String?  @unique
  source        String   @default("MANUAL") // ETSY, SHOPIFY, MANUAL
  customerName  String?
  totalAmount   Float
  currency      String   @default("USD")
  status        String   // PENDING, CUTTING, COMPLETED, SHIPPED, DELIVERED, RETURNED, CANCELLED
  notes         String?  // Terziye özel notlar
  shippingAddress String? // Gönderim adresi (opsiyonel)
  deadline      DateTime? // Son teslim tarihi (opsiyonel)
  orderDate     DateTime @default(now())
  
  // Kargo Bilgileri
  shippingLabel String?  // UPS barkod URL veya ID
  trackingCode  String?

  items         OrderItem[]
  returns       OrderReturn[]
  reorderOf     OrderReturn[] @relation("ReorderReturn")
}

// Sipariş Kalemleri
model OrderItem {
  id              Int      @id @default(autoincrement())
  orderId         Int
  productId       Int?     // Eğer sistemde tanımlıysa
  productName     String   // Tanımlı değilse adını sakla
  quantity        Int
  unitPrice       Float
  
  fabricCode      String?  // Kumaş kodu (Örn: KMS-001, PLY-BLUE)
  selectedOptions String?  // Seçilen seçenekler (Örn: "Header Tipi: Tab Top, Astar: Lined")

  // Custom ölçüler (Etsy'den gelen varyasyonlar için)
  widthInch   Float?
  heightInch  Float?

  order       Order    @relation(fields: [orderId], references: [id])
  product     Product? @relation(fields: [productId], references: [id])
}

// Stok Hareket Geçmişi
model StockMovement {
  id          Int      @id @default(autoincrement())
  materialId  Int
  change      Float    // + veya - miktar
  type        String   // PURCHASE, PRODUCTION, ADJUSTMENT
  reason      String?
  createdAt   DateTime @default(now())

  material    Material @relation(fields: [materialId], references: [id])
}

// İade / İptal Kayıtları
model OrderReturn {
  id            Int      @id @default(autoincrement())
  orderId       Int
  type          String   // RETURN, CANCEL
  reason        String   // WRONG_PRODUCT, LATE_DELIVERY, CUSTOMER_CHANGED_MIND, DEFECTIVE, OTHER
  notes         String?
  addedToStock  Boolean  @default(false)  // Ürün stoğa eklendi mi?
  reorderId     Int?     // Yeniden oluşturulan sipariş ID
  createdAt     DateTime @default(now())

  order         Order    @relation(fields: [orderId], references: [id])
  reorder       Order?   @relation("ReorderReturn", fields: [reorderId], references: [id])

  @@map("Return")
}
